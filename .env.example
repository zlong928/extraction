# Online database (PostgreSQL in production; SQLite is supported only for local development/tests)
DATABASE_URL=postgresql+psycopg://extraction:change-me@localhost:5433/extraction
REDIS_URL=redis://localhost:6380/0

# Object storage: use the same S3-compatible MinIO service as Docker Compose
STORAGE_BACKEND=s3
STORAGE_LOCAL_ROOT=./data/objects
S3_BUCKET=extraction
S3_PREFIX=production
S3_ENDPOINT_URL=http://localhost:9000
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=replace-me
AWS_SECRET_ACCESS_KEY=replace-me

# Versioned extraction provenance
PIPELINE_VERSION=content-pipeline.v1
PROMPT_VERSION=content-pipeline-prompts.v1

# External services (never commit real credentials)
MINERU_API_KEY=
MINERU_API_BASE_URL=https://mineru.net
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
VLM_BASE_URL=https://api.stepfun.com/step_plan/v1
VLM_MODEL=step-3.7-flash
VLM_API_FORMAT=openai_chat
